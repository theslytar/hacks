#include <string>

namespace MCTea
{
    class ClientCore
    {
    private:
        std::string version = "2.4.1";
        bool initialized = false;

    public:
        void Initialize()
        {
            initialized = true;

            Console::Print(
                "[MCTea] Client initialized"
            );

            LoadModules();
            LoadTheme();
            VerifyConfig();
        }

        void LoadModules()
        {
            Console::Print(
                "[MCTea] Loading modules..."
            );
        }

        void LoadTheme()
        {
            Console::Print(
                "[MCTea] Applying theme..."
            );
        }

        void VerifyConfig()
        {
            Console::Print(
                "[MCTea] Configuration verified"
            );
        }

        std::string GetVersion()
        {
            return version;
        }
    };
}
